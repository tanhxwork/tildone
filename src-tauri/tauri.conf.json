{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tildone",
  "version": "0.1.0",
  "identifier": "com.tildone.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["tildone"]
      }
    },
    "opener": {
      "requireLiteralLeadingDot": false
    }
  },
  "app": {
    "windows": [
      {
        "title": "Tildone",
        "width": 1360,
        "height": 860,
        "minWidth": 860,
        "minHeight": 560,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"],
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/attachments/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "resources": [
      "resources/tildone-heartbeat.sh"
    ],
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
